# Copy to .env and fill in as services come online. The fetch/load/search
# scripts need nothing here — Grants.gov search requires no key.

DATABASE_URL=postgresql://claimable:claimable@localhost:5433/claimable

# Required for the Criteria Compiler (scripts/compile_criteria.py).
# Get one at https://platform.claude.com/ → API keys.
ANTHROPIC_API_KEY=

# Optional overrides
# COMPILER_MODEL=claude-opus-4-8
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Later
# SAM_GOV_API_KEY=          # free key: https://sam.gov/apis
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
